# ===== Cloudflare Access Service Token =====
# 在 Cloudflare Zero Trust → Access controls → Service credentials → Service Tokens 创建
# Client Secret 只会显示一次，生成后立即复制到此处
CF_ACCESS_CLIENT_ID=xxxxxxxxxxxxxxxx.access
CF_ACCESS_CLIENT_SECRET=your_long_secret_here

# 逗号分隔，匹配哪些 base_url 需要自动注入 CF Access Header
# 默认只对自己的 einsphoton.ren 域名注入，调用 DeepSeek/OpenAI 等公共 API 时不会附带
CF_ACCESS_HOSTS=einsphoton.ren
