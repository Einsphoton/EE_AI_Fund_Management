# ===== Cloudflare Access Service Token =====
# 在 Cloudflare Zero Trust → Access controls → Service credentials → Service Tokens 创建
# Client Secret 只会显示一次，生成后立即复制到此处
CF_ACCESS_CLIENT_ID=xxxxxxxxxxxxxxxx.access
CF_ACCESS_CLIENT_SECRET=your_long_secret_here

# 逗号分隔，匹配哪些 base_url 需要自动注入 CF Access Header
# 默认只对自己的 einsphoton.ren 域名注入，调用 DeepSeek/OpenAI 等公共 API 时不会附带
CF_ACCESS_HOSTS=einsphoton.ren

# ===== 在线更新 / NAS Docker 镜像 =====
# 绿联 NAS Docker GUI 如果只认 hub.docker.com，建议填 Docker Hub 镜像。
# EE_FUND_IMAGE=docker.io/<your-dockerhub-username>/ee-fund-management:latest
# UPDATE_DOCKERHUB_REPO=<your-dockerhub-username>/ee-fund-management

# 网页上点击「立即更新」需要 Watchtower HTTP API。生产环境请设置为足够长的随机字符串。
UPDATE_ENABLE_WEB_TRIGGER=false
UPDATE_WATCHTOWER_TOKEN=change-me-to-a-long-random-token
UPDATE_WATCHTOWER_URL=http://ee-fund-watchtower:8080/v1/update
